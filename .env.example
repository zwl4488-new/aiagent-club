# 复制为 .env 后填入真实值(.env 已在 .gitignore,不会提交)。
# 真实凭据只放 .env,绝不放本文件 —— 本文件会被 git 跟踪并提交到 public 仓库。

# ── Cloudflare R2(私有 bucket,存 data.db)──
# 四个值来自 Cloudflare R2 → Manage API Tokens,token 只授权本 bucket 的读写(Object Read&Write)。
# Secret Access Key 只在创建 token 时显示一次,当场存好。
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=aiagent-club-data
# S3 兼容端点(R2 → Settings 里给出,形如 https://<account_id>.r2.cloudflarestorage.com)。
# 设了就优先用它;留空则由 config.mjs 从 R2_ACCOUNT_ID 推出。
S3_API_ENDPOINT=

# ── GitHub(GraphQL 抓取用)──
# 只读 public repo 指标,权限取最小:classic token 不勾任何 scope,或 fine-grained 选
# "Public repositories (read-only)"。认证后 5000 point/小时。
# CI 里用 Actions 自带的 secrets.GITHUB_TOKEN,无需在此配。
GITHUB_TOKEN=

# ── OpenRouter(模型每日 token 用量排行,可选)──
# 模型定价(/models)公开无需 key,已在采集。此 key 仅用于 rankings-daily(全球唯一公开的
# "模型真实使用量"信号,含大量国产模型)。在 openrouter.ai 免费注册 → Keys 里生成即可。
# 留空则跳过用量、只采定价。CI 里加同名 Actions secret 才会在云端生效。
OPENROUTER_API_KEY=
