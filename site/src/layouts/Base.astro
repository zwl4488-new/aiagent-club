---
import '../styles/global.css'
// props: locale ('en'|'zh'), title, description, path ('/' or '/zh/')
const { locale = 'en', title, description, path = '/' } = Astro.props
const SITE = 'https://aiagent.club'
---
<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={SITE + path} />
    <!-- hreflang 互指:/ 英文兼 x-default,/zh/ 中文 -->
    <link rel="alternate" hreflang="en" href={SITE + '/'} />
    <link rel="alternate" hreflang="zh" href={SITE + '/zh/'} />
    <link rel="alternate" hreflang="x-default" href={SITE + '/'} />
    <meta name="theme-color" content="#6366f1" />
    <!-- 主题在首帧前就应用,避免刷新时亮/暗闪烁(FOUC)。 -->
    <script is:inline>
      const saved = localStorage.getItem('theme')
      if (saved === 'dark' || saved === 'light') document.documentElement.dataset.theme = saved
    </script>
  </head>
  <body>
    <div class="wrap">
      <slot />
    </div>
  </body>
</html>
