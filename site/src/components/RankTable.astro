---
import Sparkline from './Sparkline.astro'
import { compact, full } from '../lib/format.mjs'
// props:
//  title, note
//  rows: [{ entity_id, name, url, values:{}, spark:[{captured_at,value}] }]
//  columns: [{ key, label, primary? }]
//  trendLabel: string
//  base: '' | '/zh'(内链前缀)
//  more: { href, label }(可选,表尾"查看全部"链接)
const { title, note, rows = [], columns = [], trendLabel, base = '', more = null } = Astro.props
// entity_id 'github:owner/name' → 详情页路径 '/p/github/owner/name'(替换首个 ':')。
const detailHref = (entityId) => `${base}/p/${entityId.replace(':', '/')}`
---
<section class="rank">
  <h2>{title}</h2>
  <p class="note">{note}</p>
  <div class="table-scroll">
    <table>
      <thead>
        <tr>
          <th>#</th>
          <th>Name</th>
          {columns.map((c) => <th>{c.label}</th>)}
          <th>{trendLabel}</th>
        </tr>
      </thead>
      <tbody>
        {rows.map((row, i) => (
          <tr>
            <td><span class="idx">{i + 1}</span></td>
            <td><a class="name" href={detailHref(row.entity_id)}>{row.name}</a></td>
            {columns.map((c) => (
              <td class={c.primary ? 'primary' : ''} title={full(row.values[c.key])}>{compact(row.values[c.key])}</td>
            ))}
            <td><Sparkline points={row.spark} /></td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
  {more && <p class="rank-more"><a href={more.href}>{more.label}</a></p>}
</section>
