---
import Base from '../layouts/Base.astro'
import Hero from './Hero.astro'
import IndexCards from './IndexCards.astro'
import RankCard from './RankCard.astro'
import Movers from './Movers.astro'
import HypeGap from './HypeGap.astro'
import { overview, ranking, movers, latestMap, seriesByKind } from '../lib/data.mjs'
import { hypeVsUsage, buildProjects } from '../lib/projects.mjs'
import { t } from '../lib/i18n.mjs'
import { compact, full } from '../lib/format.mjs'

// 时序降采样到 ≤N 点(卡片里的小折线用)。
function downsample(points, max = 40) {
  if (points.length <= max) return points
  const step = (points.length - 1) / (max - 1)
  const out = []
  for (let i = 0; i < max; i++) out.push(points[Math.round(i * step)])
  return out
}

const { locale = 'en' } = Astro.props
const s = t(locale)
const path = locale === 'zh' ? '/zh/' : '/'
const base = locale === 'zh' ? '/zh' : ''

const ov = await overview()
const KINDB = { github: 'GH', npm: 'npm', pypi: 'PyPI', huggingface: 'HF', openrouter: 'OR', modelscope: 'MS', vscode: 'VSC' }

// 旗舰:统一项目综合指数(top 10)。
const projects = await buildProjects()
const indexRows = projects.slice(0, 10).map((p) => ({
  name: p.name,
  href: `${base}/project/${p.slug}`,
  value: p.score,
  bar: p.score,
  badges: p.kinds.filter((k) => KINDB[k]).map((k) => KINDB[k]),
  title: `score ${p.score}`,
}))

// 各源榜(每源 top 10)→ 卡片行,含小折线(spark 走有历史的指标)。长尾在 /browse。
const detailHref = (entityId) => `${base}/p/${entityId.replace(':', '/')}`
function srcRows(rows, key, sparkMap) {
  return rows.slice(0, 10).map((r) => ({
    name: r.name,
    href: detailHref(r.entity_id),
    value: compact(r.values[key]),
    title: full(r.values[key]),
    spark: downsample(sparkMap.get(r.entity_id) ?? []),
  }))
}
const [orusage, gh, npm, pypi, vscode, modelscope, hf] = await Promise.all([
  ranking('openrouter', 'or_tokens_day', ['or_tokens_day']),
  ranking('github', 'stars', ['stars']),
  ranking('npm', 'downloads_week', ['downloads_week']),
  ranking('pypi', 'downloads_month', ['downloads_month']),
  ranking('vscode', 'vscode_installs', ['vscode_installs']),
  ranking('modelscope', 'ms_downloads', ['ms_downloads']),
  ranking('huggingface', 'hf_downloads', ['hf_downloads']),
])
// 各源 sparkline 时序(每 kind 一次查询)。npm/pypi 走日下载(历史深),其余走主指标。
const [spOr, spGh, spNpm, spPypi, spVs, spMs, spHf] = await Promise.all([
  seriesByKind('openrouter', 'or_tokens_day'),
  seriesByKind('github', 'stars'),
  seriesByKind('npm', 'downloads_day'),
  seriesByKind('pypi', 'downloads_day'),
  seriesByKind('vscode', 'vscode_installs'),
  seriesByKind('modelscope', 'ms_downloads'),
  seriesByKind('huggingface', 'hf_downloads'),
])

// 右栏洞察:本周异动(7 天 star 增量)+ 热度落差。
const starMovers = (await movers('github', 'stars', 7)).sort((a, b) => b.delta - a.delta).slice(0, 8)
const [starMap, dlMonthMap, dlWeekMap] = await Promise.all([latestMap('stars'), latestMap('downloads_month'), latestMap('downloads_week')])
const hype = hypeVsUsage(starMap, dlMonthMap, dlWeekMap)
const overhyped = [...hype].sort((a, b) => b.gap - a.gap).slice(0, 6)
const underrated = [...hype].sort((a, b) => a.gap - b.gap).slice(0, 6)
---
<Base locale={locale} title={`aiagent.club — ${s.tagline}`} description={s.intro} path={path}>
  <nav class="topnav">
    <a href={`${base}/`} aria-current="page">{s.nav.rankings}</a>
    <a href={`${base}/changes`}>{s.nav.changelog}</a>
    <a href={`${base}/pricing`}>{s.nav.pricing}</a>
    <a href={`${base}/browse`}>{s.nav.browse}</a>
    <a href={`${base}/methodology`}>{s.nav.methodology}</a>
    <a href={`${base}/search`}>{s.nav.search}</a>
  </nav>

  <Hero s={s} ov={ov} />

  <div class="home-grid">
    <div class="home-main">
      <IndexCards title={s.index.title} note={s.index.note} rows={projects.slice(0, 10)} s={s} base={base} moreHref={`${base}/projects`} moreLabel={s.index.full} />
      {orusage.length > 0 && <RankCard title={s.orusage} rows={srcRows(orusage, 'or_tokens_day', spOr)} accent="#4f46e5" />}
      <RankCard title={s.github} rows={srcRows(gh, 'stars', spGh)} accent="#d97706" />
      <RankCard title={s.npm} rows={srcRows(npm, 'downloads_week', spNpm)} accent="#e11d48" />
      <RankCard title={s.pypi} rows={srcRows(pypi, 'downloads_month', spPypi)} accent="#0284c7" />
      {vscode.length > 0 && <RankCard title={s.vscode} rows={srcRows(vscode, 'vscode_installs', spVs)} accent="#7c3aed" />}
      {hf.length > 0 && <RankCard title={s.hf} rows={srcRows(hf, 'hf_downloads', spHf)} accent="#0891b2" />}
      {modelscope.length > 0 && <RankCard title={s.modelscope} rows={srcRows(modelscope, 'ms_downloads', spMs)} accent="#db2777" />}
    </div>

    <aside class="home-side">
      <Movers title={s.moversTitle} note={s.moversNote} rows={starMovers} gained={s.gained} now={s.now} base={base} />
      {overhyped.length > 0 && (
        <HypeGap
          title={s.hypeTitle}
          note={s.hypeNote}
          overhyped={overhyped}
          underrated={underrated}
          overLabel={s.overhyped}
          underLabel={s.underrated}
          starsShort={s.starsShort}
          dlMo={s.dlMo}
          base={base}
        />
      )}
    </aside>
  </div>

  <p class="browse-cta"><a href={`${base}/browse`}>{s.browseAll(ov.entities)}</a></p>
  <footer class="site">{s.footer}</footer>
</Base>
