---
import Base from '../layouts/Base.astro'
import RankTable from './RankTable.astro'
import { overview, ranking, series } from '../lib/data.mjs'
import { t } from '../lib/i18n.mjs'

const { locale = 'en' } = Astro.props
const s = t(locale)
const path = locale === 'zh' ? '/zh/' : '/'
const otherPath = locale === 'zh' ? '/' : '/zh/'

const ov = await overview()

// 把时序降采样到 ≤N 点(周粒度足够画 sparkline;避免把上千个日点打进 HTML)。
function downsample(points, max = 48) {
  if (points.length <= max) return points
  const step = (points.length - 1) / (max - 1)
  const out = []
  for (let i = 0; i < max; i++) out.push(points[Math.round(i * step)])
  return out
}

// 为一批排名行补上 sparkline 时序。sparkMetric 用已回填的历史指标,曲线才有内容。
async function withSpark(rows, sparkMetric) {
  return Promise.all(rows.map(async (r) => ({ ...r, spark: downsample(await series(r.entity_id, sparkMetric)) })))
}

// 排序仍按各源主指标;sparkline 走有历史的指标(github→commits 累计,npm/pypi→日下载)。
const gh = await withSpark(await ranking('github', 'stars', ['stars', 'forks', 'commits']), 'commits')
const npm = await withSpark(await ranking('npm', 'downloads_week', ['downloads_week']), 'downloads_day')
const pypi = await withSpark(
  await ranking('pypi', 'downloads_month', ['downloads_month', 'downloads_week']),
  'downloads_day'
)

const cols = s.cols
const ghCols = [
  { key: 'stars', label: cols.stars, primary: true },
  { key: 'forks', label: cols.forks },
  { key: 'commits', label: cols.commits },
]
const npmCols = [{ key: 'downloads_week', label: cols.dl, primary: true }]
const pypiCols = [
  { key: 'downloads_month', label: cols.dl, primary: true },
  { key: 'downloads_week', label: 'Week' },
]
---
<Base locale={locale} title={`aiagent.club — ${s.tagline}`} description={s.intro} path={path}>
  <header class="site">
    <div>
      <h1>aiagent<span class="dot">.</span>club</h1>
      <p class="tagline">{s.tagline}</p>
    </div>
    <div class="controls">
      <button id="theme-toggle" class="icon-btn" type="button" aria-label={s.theme} title={s.theme}>
        <svg class="sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><circle cx="12" cy="12" r="4"></circle><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"></path></svg>
        <svg class="moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"></path></svg>
      </button>
      <a class="langlink" href={otherPath} data-astro-prefetch="hover">{s.switchLang}</a>
    </div>
  </header>

  <p class="intro">{s.intro}</p>
  <p class="early">{s.early}</p>

  <div class="stats">
    <div class="stat"><b>{ov.entities}</b><span>{s.entities}</span></div>
    <div class="stat"><b>{ov.metrics}</b><span>{s.dataPoints}</span></div>
    <div class="stat"><b>{ov.days}</b><span>{s.days}</span></div>
    <div class="stat"><b>{ov.latest}</b><span>{s.snapshot}</span></div>
  </div>

  <RankTable title={s.github} note={s.githubNote} rows={gh} columns={ghCols} trendLabel={s.trend} />
  <RankTable title={s.npm} note={s.npmNote} rows={npm} columns={npmCols} trendLabel={s.trend} />
  <RankTable title={s.pypi} note={s.pypiNote} rows={pypi} columns={pypiCols} trendLabel={s.trend} />

  <footer class="site">{s.footer}</footer>

  <script is:inline>
    // 开了 ClientRouter 后,is:inline 脚本不在 SPA 跳转后重跑;把绑定挂到 astro:page-load,
    // 它在首屏与每次视图切换后都会触发,保证切换语言后按钮仍可用。document 跨切换不被替换。
    function setupTheme() {
      const root = document.documentElement
      const current = () =>
        root.dataset.theme || (matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light')
      root.setAttribute('data-mode', current())
      const btn = document.getElementById('theme-toggle')
      if (btn && !btn.dataset.bound) {
        btn.dataset.bound = '1'
        btn.addEventListener('click', () => {
          const next = current() === 'dark' ? 'light' : 'dark'
          root.dataset.theme = next
          localStorage.setItem('theme', next)
          root.setAttribute('data-mode', next)
        })
      }
    }
    document.addEventListener('astro:page-load', setupTheme)
    // 兜底:无 ClientRouter 的环境(如自包含预览)astro:page-load 不会触发,直接初始化一次。
    if (document.readyState !== 'loading') setupTheme()
    else document.addEventListener('DOMContentLoaded', setupTheme)
  </script>
</Base>
