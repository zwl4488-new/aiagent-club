---
import Base from '../../layouts/Base.astro'
import ProjectDetail from '../../components/ProjectDetail.astro'
import { buildProjectPages } from '../../lib/projects.mjs'
import { t } from '../../lib/i18n.mjs'
import { compact } from '../../lib/format.mjs'

export async function getStaticPaths() {
  const projects = await buildProjectPages()
  return projects.map((project) => ({ params: { slug: project.slug }, props: { project } }))
}

const { project } = Astro.props
const s = t('en')
const path = `/project/${project.slug}`
const stat = project.usage > 0 ? `${compact(project.usage)}/mo` : project.stars > 0 ? `${compact(project.stars)} stars` : ''
const title = `${project.name} — AI Agent Index | aiagent.club`
const description = project.intro ? `${project.name}: ${project.intro.slice(0, 140)}` : `${project.name} — score ${project.score} in the AI Agent Index. ${stat}. Unified GitHub + package + model metrics, tracked daily by aiagent.club.`
---
<Base locale="en" title={title} description={description} path={path} altEn={path} altZh={`/zh/project/${project.slug}`}>
  <ProjectDetail project={project} s={s} base="" />
</Base>
