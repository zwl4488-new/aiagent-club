---
import Base from '../../layouts/Base.astro'
import EntityDetail from '../../components/EntityDetail.astro'
import { buildEntityPages } from '../../lib/detail.mjs'
import { t } from '../../lib/i18n.mjs'
import { compact } from '../../lib/format.mjs'

export async function getStaticPaths() {
  const pages = await buildEntityPages()
  return pages.map((entity) => ({ params: { slug: entity.slug }, props: { entity } }))
}

const { entity } = Astro.props
const s = t('en')
const path = `/p/${entity.slug}`
const kindLabel = s.kindLabel[entity.kind] ?? entity.kind
const stat =
  entity.primaryValue != null ? `${compact(entity.primaryValue)} ${s.metricLabel[entity.primaryMetric] ?? ''}.` : ''
const title = `${entity.name} — ${kindLabel} | aiagent.club`
const description = entity.description
  ? s.detail.metaDescReal(entity.name, entity.description, stat)
  : s.detail.metaDesc(entity.name, kindLabel, stat)

// 结构化数据:本页是"某项目指标随时间"的数据集。github 再挂 SoftwareSourceCode。
const SITE = 'https://www.aiagent.club'
const jsonld = {
  '@type': 'Dataset',
  name: `${entity.name} — metrics over time`,
  description,
  url: SITE + path,
  isAccessibleForFree: true,
  creator: { '@id': `${SITE}/#org` },
  keywords: [kindLabel, 'AI agent', entity.category].filter(Boolean),
  variableMeasured: Object.keys(entity.metrics).map((m) => s.metricLabel[m] ?? m),
  ...(entity.kind === 'github' && entity.url ? { about: { '@type': 'SoftwareSourceCode', name: entity.name, codeRepository: entity.url } } : {}),
}
---
<Base locale="en" title={title} description={description} path={path} altEn={path} altZh={`/zh/p/${entity.slug}`} jsonld={jsonld}>
  <EntityDetail entity={entity} s={s} base="" />
</Base>
